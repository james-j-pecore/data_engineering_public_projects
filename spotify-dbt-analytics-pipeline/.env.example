# Spotify Developer app credentials: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Must exactly match a Redirect URI registered on your Spotify app
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080/callback

# Optional overrides — defaults shown
DUCKDB_PATH=data/spotify.duckdb
TOKEN_CACHE_PATH=.spotify_token_cache.json
